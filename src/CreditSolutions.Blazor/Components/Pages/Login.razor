@page "/login"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@inject IHttpContextAccessor HttpContextAccessor

<main class="login-page">
    <section class="login-panel">
        <h1>CSS Credit Solutions</h1>
        <p>Collector sign in</p>

        <form method="post" action="/login" data-enhance @formname="login">
            <AntiforgeryToken />
            <input name="Email" placeholder="Email" autocomplete="email" value="collector@css.local" />
            <input name="Password" type="password" placeholder="Password" autocomplete="current-password" />
            <button type="submit">Sign In</button>
        </form>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <p class="notice">@_error</p>
        }
    </section>
</main>

@code {
    [SupplyParameterFromForm]
    public string Email { get; set; } = string.Empty;

    [SupplyParameterFromForm]
    public string Password { get; set; } = string.Empty;

    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        // Only process login when form data was posted (not on initial GET)
        if (HttpContextAccessor.HttpContext?.Request.Method != "POST")
            return;

        if (!string.Equals(Email, "collector@css.local", StringComparison.OrdinalIgnoreCase) ||
            Password != "Password123!")
        {
            _error = $"Invalid demo credentials. Email=[{Email}] PwdLen={Password.Length}";
            return;
        }

        var claims = new List<Claim>
        {
            new(ClaimTypes.NameIdentifier, "10000000-0000-0000-0000-000000000001"),
            new(ClaimTypes.Name, "Demo Collector"),
            new(ClaimTypes.Email, Email)
        };

        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(identity);

        await HttpContextAccessor.HttpContext!.SignInAsync(
            CookieAuthenticationDefaults.AuthenticationScheme,
            principal);

        HttpContextAccessor.HttpContext!.Response.Redirect("/");
    }
}
