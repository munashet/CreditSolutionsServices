    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (Blazor)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/CreditSolutions.Blazor/bin/Debug/net10.0/CreditSolutions.Blazor.dll",
            "args": [],
